{
  "name": "@vibecontrols/vibe-plugin-security-scorecard",
  "version": "2026.528.2",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "description": "OpenSSF Scorecard checks at the main.merge lifecycle stage. Runs `scorecard --repo file://<path>` for offline checks and `--repo <url>` when GH_TOKEN is present for full set.",
  "engines": {
    "bun": ">=1.3.14"
  },
  "author": {
    "name": "Vignesh T.V",
    "email": "vignesh@burdenoff.com",
    "url": "https://github.com/tvvignesh"
  },
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --minify-syntax --minify-whitespace --external elysia --external @vibecontrols/vibe-plugin-security --external @vibecontrols/plugin-sdk && tsc --emitDeclarationOnly --declaration --outDir ./dist",
    "dev": "tsc --watch",
    "lint": "eslint ./src ./tests",
    "format": "bunx prettier . --write",
    "format:check": "bunx prettier . --check",
    "type:check": "tsc --noEmit",
    "test": "bun test ./tests",
    "clean": "rimraf dist",
    "prebuild": "bun run clean",
    "prepublishOnly": "bun run build",
    "sanity": "bun run format:check && bun run lint && bun run type:check && bun run test && bun run build"
  },
  "dependencies": {
    "@vibecontrols/plugin-sdk": "2026.527.1",
    "@vibecontrols/vibe-plugin-security": "2026.528.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.9",
    "eslint": "^9.30.1",
    "globals": "^17.3.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  },
  "peerDependencies": {
    "@vibecontrols/agent": ">=2026.428.0"
  },
  "peerDependenciesMeta": {
    "@vibecontrols/agent": {
      "optional": true
    }
  },
  "keywords": [
    "vibecontrols",
    "vibe",
    "vibe-plugin",
    "security",
    "scorecard",
    "openssf",
    "main-merge",
    "bun"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/algoshred/vibe-plugin-security-scorecard.git"
  },
  "bugs": {
    "url": "https://github.com/algoshred/vibe-plugin-security-scorecard/issues"
  },
  "homepage": "https://vibecontrols.com",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist/**/*",
    "!dist/**/*.map",
    "README.md",
    "LICENSE"
  ]
}
